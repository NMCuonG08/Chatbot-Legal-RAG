# API Keys
GROQ_API_KEY=gsk_your_groq_api_key_here
TAVILY_API_KEY=tvly-your_tavily_key_here
COHERE_API_KEY=your_cohere_key_here

# Database Configurations
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/legal_chatbot
REDIS_URL=redis://127.0.0.1:6379/0
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# Neo4j legal knowledge graph (Phase 3). Optional — when NEO4J_URI is empty,
# graph memory is disabled and the agent falls back to vector retrieval.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j

# LLM Provider Configuration (groq, ollama, openai)
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant

# Ollama / Ollama Cloud Configurations (Set to https://ollama.com for Ollama Cloud)
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=
OLLAMA_LLM_MODEL=gemma4:31b
OLLAMA_FAST_LLM_MODEL=qwen2.5:7b

# Vietnamese Legal RAG Generation LLM Configuration
VIETNAMESE_LLM_API_URL=http://3.89.75.45:6000/v1/chat/completions

CUSTOM_EMBEDDING_API_URL=http://localhost:5000
CUSTOM_EMBEDDING_ENABLED=true

# Reranker Configuration (cohere, bge, none)
RERANKER_TYPE=cohere
BGE_RERANK_MODEL=BAAI/bge-reranker-v2-m3
BGE_RERANK_DEVICE=cpu

# ---- MCP server (Phase 1) ----
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_HTTP_PORT=8100
# Single shared bearer key authorizing all MCP HTTP clients (streamable-http).
# Required when MCP_TRANSPORT=http. Generate: python -c "import secrets;print(secrets.token_urlsafe(32))"
# Clients send header: Authorization: Bearer <MCP_API_KEY>
MCP_API_KEY=
# Dev only: serve HTTP with NO auth check when MCP_API_KEY is unset. NEVER enable in production.
MCP_ALLOW_NO_AUTH=0

# ---- Security: JWT auth + RBAC (Phase 2) ----
# Required in production. If unset, /auth/* endpoints refuse unless ALLOW_UNSAFE_AUTH=1.
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALG=HS256
JWT_EXP_MIN=60
# Allow anonymous /chat/complete (demo) without a JWT. Set to 0 in production.
ALLOW_ANONYMOUS=1
# When JWT_SECRET is unset, allow auth endpoints anyway (dev only).
ALLOW_UNSAFE_AUTH=0
# Default admin seeded on startup (best-effort).
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=change-me

# LangSmith Tracing Configuration
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=Vietnamese-Legal-Chatbot
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com


