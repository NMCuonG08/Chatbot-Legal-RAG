# OS files
.DS_Store
Thumbs.db

# Python bytecode and cache
__pycache__/
*.py[cod]
*$py.class

# Python virtual environments
.venv/
venv/
env/
ENV/
# Exception: deployment/env/ holds deploy env TEMPLATES (not a Python venv).
# The env/ rule above would ignore it; this re-includes the dir so the
# .env.prod.aws.example + SECRETS_CHECKLIST.md templates commit normally.
!deployment/env/

# Packaging/build artifacts
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Test, type-check, and coverage caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Jupyter
.ipynb_checkpoints/

# Logs and runtime temp files
*.log
*.pid
*.out
*.err

# Data files
*.jsonl

# Environment and secrets
.env
.env.*
!.env.example
!.env.prod.aws.example
!.env.*.example

# Terraform: never commit filled tfvars (has IPs), keep .example
deployment/terraform/terraform.tfvars
*.tfstate
*.tfstate.backup
*.tfstate.lock.info
.terraform/
# SSH private key (generated by ssh-keygen). PUBLIC key (.pub) is committed —
# terraform registers it with AWS via aws_key_pair. Private key never leaves you.
deployment/terraform/legal-prod-key
!deployment/terraform/legal-prod-key.pub

# Filled model registry (keep .example). Commit if no secret inside.
backend/models.yaml

# IDE/editor
.vscode/
.idea/
*.swp
*.swo

# Docker/local container data
qdrant_storage/
*.sqlite3

data/
backend/data/
data_pipeline/data/

# Project-specific generated artifacts
llm_finetuning_serving/final_model/
llm_finetuning_serving/outputs/
llm_finetuning_serving/checkpoints/

# Gradio cache
.gradio/

# Downloaded embedding / serving model artifacts (HF cache, multi-GB)
embed_serving/models/

# Native Qdrant database and binaries
storage/
qdrant-win/
qdrant.zip
.qdrant-initialized



