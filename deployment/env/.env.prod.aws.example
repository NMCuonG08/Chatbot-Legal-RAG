# ============================================================================
# LEGAL CHATBOT — PRODUCTION ENV (AWS SINGLE-EC2 DEPLOYMENT)
# ----------------------------------------------------------------------------
# Copy this file to backend/.env on the EC2 instance and fill real values.
# NEVER commit the filled file. backend/.env is gitignored.
# Where to get each key: see deployment/env/SECRETS_CHECKLIST.md
# Generate secrets locally: python -c "import secrets;print(secrets.token_urlsafe(32))"
# ============================================================================

# ===================== 1. LLM PROVIDER API KEYS =============================
# Groq — primary LLM + judge. Get: https://console.groq.com/keys
GROQ_API_KEY=gsk_PLACEHOLDER_GROQ_KEY

# Tavily — web search tool. Optional. Get: https://app.tavily.com/api-key
TAVILY_API_KEY=tvly-PLACEHOLDER_TAVILY_KEY

# Cohere — reranker. Optional (fallback passthrough if empty). Get: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=PLACEHOLDER_COHERE_KEY

# LangSmith — LangChain tracing. Optional. Get: https://smith.langchain.com/settings
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=lsv2_pt_PLACEHOLDER
LANGCHAIN_PROJECT=Vietnamese-Legal-Chatbot-prod
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ===================== 2. LLM ROUTING =======================================
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant
# Fallback provider (local Ollama on EC2 or Ollama Cloud). Get Ollama key: https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=
OLLAMA_LLM_MODEL=qwen2.5:7b
OLLAMA_FAST_LLM_MODEL=qwen2.5:0.5b

# Fine-tuned Vietnamese LLM endpoint (GPU serving box). Leave empty to use Groq only.
VIETNAMESE_LLM_API_URL=

# ===================== 3. EMBEDDING + RERANKER ==============================
CUSTOM_EMBEDDING_ENABLED=true
CUSTOM_EMBEDDING_API_URL=http://localhost:5000
# Reranker: cohere | bge | none
RERANKER_TYPE=cohere
BGE_RERANK_MODEL=BAAI/bge-reranker-v2-m3
BGE_RERANK_DEVICE=cpu

# Retrieval tuning (RRF hybrid)
RRF_W_VECTOR=1.15
RRF_W_BM25=1.0
RRF_BLEND_ALPHA=0.6
RRF_TOP_K=4
RRF_TOP_N=5
RERANK_TOP_N=3

# ===================== 4. DATABASES (docker internal DNS) ===================
# Use docker service names, NOT localhost, when running in compose.
# MariaDB container creds (docker-compose.prod.yml mariadb service reads these).
# The password in DATABASE_URL MUST match MYSQL_PASSWORD below.
MYSQL_PASSWORD=CHANGE_ME_STRONG_DB_PASS
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_DB_ROOT_PASS
DATABASE_URL=mysql+pymysql://legal:CHANGE_ME_STRONG_DB_PASS@mariadb:3306/legal_db
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# Neo4j legal knowledge graph (optional; empty = graph disabled)
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ===================== 5. SECURITY: JWT + RBAC (PROD = STRONG) ==============
# Generate 32+ byte random: python -c "import secrets;print(secrets.token_urlsafe(32))"
JWT_SECRET=CHANGE_ME_TO_LONG_RANDOM_32BYTE_STRING
JWT_ALG=HS256
JWT_EXP_MIN=60
# PROD: anonymous chat OFF
ALLOW_ANONYMOUS=0
# PROD: unsafe auth OFF
ALLOW_UNSAFE_AUTH=0
# Default admin seeded on startup — CHANGE password immediately after first boot
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=CHANGE_ME_ADMIN_BOOTSTRAP

# ===================== 6. MCP SERVER ========================================
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_HTTP_PORT=8100
# Generate bearer key: python -c "import secrets;print(secrets.token_urlsafe(32))"
MCP_API_KEY=CHANGE_ME_MCP_BEARER_32BYTE
# PROD: NEVER allow no-auth
MCP_ALLOW_NO_AUTH=0

# ===================== 7. GUARDRAILS + P6 (PROD TOGGLES) ====================
# PII redaction on output (eval-time). Legal app: keep true in prod.
GUARDRAILS_PII_OUTPUT_ENABLED=true
# OTel span mirror to collector (optional). Turn on if collector deployed.
OTEL_BRIDGE_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Cost routing: route legal_rag → big model, rest → small. PROD: on.
COST_ROUTING_ENABLED=true
# Shadow candidate (DOUBLES Groq cost). PROD: off unless A/B testing.
SHADOW_MODE_ENABLED=false

# ===================== 8. EVAL HARNESS (nightly CI uses these too) =========
JUDGE_PROVIDER=groq
JUDGE_MODEL=llama-3.1-8b-instant
JUDGE_TEMPERATURE=0.0
EVAL_MAX_WORKERS=8
EVAL_JUDGE_CONCURRENCY=4
REGRESSION_ALPHA=0.05

# ===================== 9. AWS INFRA (for Terraform + scripts) ==============
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=AKIA_PLACEHOLDER_AWS_ACCESS
AWS_SECRET_ACCESS_KEY=PLACEHOLDER_AWS_SECRET
# S3 bucket for Qdrant/MariaDB backups + corpus
S3_BACKUP_BUCKET=legal-chatbot-backups
S3_CORPUS_BUCKET=legal-chatbot-corpus
# EC2
EC2_INSTANCE_TYPE=t3.large
EC2_KEY_PAIR_NAME=legal-prod-key
EC2_EBS_SIZE_GB=50
# Route 53
ROUTE53_DOMAIN=yourdomain.com
ROUTE53_HOSTED_ZONE_ID=Z_PLACEHOLDER_HOSTEDZONE
# Container registry (GHCR or ECR)
REGISTRY=ghcr.io
REGISTRY_OWNER=your-github-username
REGISTRY_USERNAME=your-github-username
# PAT with write:packages scope. Get: https://github.com/settings/tokens
REGISTRY_PASSWORD=ghp_PLACEHOLDER_GHCR_PAT

# ===================== 10. MONITORING =======================================
# Grafana admin password — CHANGE from default on first boot
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_ADMIN
# Alertmanager receiver (SNS topic ARN for alerts) — optional
ALERT_SNS_TOPIC_ARN=