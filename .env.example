REDIS_URL=redis://redis:6379/0
MARIADB_DSN=mysql+pymysql://legal:legal@mariadb:3306/legal_db
QDRANT_URL=http://qdrant:6333

# ---- Retrieval / rerank tuning (Phase 2-3) ----
# RRF (Reciprocal Rank Fusion) weights for vector vs BM25 in hybrid_search.
# Defaults: vector 1.15, bm25 1.0 (slight vector lean).
RRF_W_VECTOR=1.15
RRF_W_BM25=1.0
# Blend alpha between fused hybrid score and rerank relevance score:
#   final = alpha*norm(hybrid) + (1-alpha)*norm(relevance). Default 0.6.
RRF_BLEND_ALPHA=0.6
# Hybrid retrieve top_k and rerank top_n. Keep rerank top_n >= hybrid top_k.
RRF_TOP_K=4
RRF_TOP_N=5
# Reranker: "cohere" (default, needs COHERE_API_KEY) | "bge" (local CrossEncoder)
# | anything else = disabled (passthrough, flagged rerank_failed=True).
RERANKER_TYPE=cohere
RERANK_TOP_N=3
# BGE (local) rerank model + device — only used when RERANKER_TYPE=bge.
BGE_RERANK_MODEL=BAAI/bge-reranker-v2-m3
BGE_RERANK_DEVICE=cpu